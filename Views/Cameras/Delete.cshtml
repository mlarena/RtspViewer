@model RtspViewer.Models.Camera
@{
    ViewData["Title"] = "Удалить камеру";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm border-danger">
                <div class="card-header bg-danger text-white py-2">
                    <h1 class="h5 mb-0">Удалить камеру</h1>
                </div>
                <div class="card-body p-3 text-center">
                    <div class="display-4 text-danger mb-3">⚠️</div>
                    <h3 class="h5 mb-3">Вы уверены, что хотите отключить эту камеру?</h3>
                    
                    <div class="bg-light p-3 rounded mb-3 text-start small">
                        <div class="row mb-1">
                            <div class="col-4 fw-bold">ID:</div>
                            <div class="col-8">@Model.Id</div>
                        </div>
                        <div class="row mb-1">
                            <div class="col-4 fw-bold">Название:</div>
                            <div class="col-8">@Model.Name</div>
                        </div>
                        <div class="row mb-1">
                            <div class="col-4 fw-bold">URL:</div>
                            <div class="col-8">@Model.RtspUrl</div>
                        </div>
                    </div>

                    <div class="alert alert-warning py-2 small text-start">
                        <strong>Внимание!</strong> Все сохраненные снимки с этой камеры будут удалены из системы.
                    </div>
                    
                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex justify-content-between align-items-center pt-3 border-top">
                            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Отмена</a>
                            <button type="submit" class="btn btn-danger btn-sm px-4">Удалить</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
