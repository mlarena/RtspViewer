@model RtspViewer.Models.Camera
@{
    ViewData["Title"] = "Подключить камеру";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white py-2">
                    <h1 class="h5 mb-0">Подключить новую камеру</h1>
                </div>
                <div class="card-body p-3">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
                        
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label small fw-bold"></label>
                            <input asp-for="Name" class="form-control form-control-sm" placeholder="Напр: Входная группа" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="MonitoringPostId" class="form-label small fw-bold">Пост мониторинга</label>
                            <select asp-for="MonitoringPostId" class="form-select form-select-sm" asp-items="ViewBag.MonitoringPostId">
                                <option value="">-- Выберите пост --</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label asp-for="InstallationLocation" class="form-label small fw-bold"></label>
                            <input asp-for="InstallationLocation" class="form-control form-control-sm" />
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label asp-for="SerialNumber" class="form-label small fw-bold"></label>
                                <input asp-for="SerialNumber" class="form-control form-control-sm" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Picket" class="form-label small fw-bold"></label>
                                <input asp-for="Picket" class="form-control form-control-sm" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="RtspUrl" class="form-label small fw-bold"></label>
                            <input asp-for="RtspUrl" class="form-control form-control-sm" placeholder="rtsp://..." />
                            <span asp-validation-for="RtspUrl" class="text-danger small"></span>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label asp-for="ApiRequest" class="form-label small fw-bold"></label>
                                <input asp-for="ApiRequest" class="form-control form-control-sm" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="WebUrl" class="form-label small fw-bold"></label>
                                <input asp-for="WebUrl" class="form-control form-control-sm" />
                            </div>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label asp-for="Username" class="form-label small fw-bold"></label>
                                <input asp-for="Username" class="form-control form-control-sm" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Password" class="form-label small fw-bold"></label>
                                <input asp-for="Password" type="password" class="form-control form-control-sm" />
                            </div>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label asp-for="FdaId" class="form-label small fw-bold"></label>
                                <input asp-for="FdaId" class="form-control form-control-sm" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="PollingInterval" class="form-label small fw-bold"></label>
                                <input asp-for="PollingInterval" class="form-control form-control-sm" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <input asp-for="IsPtzSupported" class="form-check-input" type="checkbox" role="switch" id="isPtz">
                                <label class="form-check-label small" for="isPtz">Поддержка PTZ (управление поворотом)</label>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center pt-2 border-top">
                            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Отмена</a>
                            <button type="submit" class="btn btn-primary btn-sm px-4">Подключить</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
