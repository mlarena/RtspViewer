@model RtspViewer.Models.Camera
@{
    ViewData["Title"] = "Просмотр камеры";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-action="Index">Камеры</a></li>
                <li class="breadcrumb-item active">@Model.Name</li>
            </ol>
        </nav>
        <div class="btn-group btn-group-sm">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Настройки</a>
            <a asp-action="Index" class="btn btn-outline-secondary">К списку</a>
        </div>
    </div>

    <div class="row g-3">
        <!-- Видеопоток и управление -->
        <div class="col-lg-8">
            <div class="card shadow-sm bg-dark text-white mb-3">
                <div class="card-header bg-transparent border-secondary py-2 d-flex justify-content-between align-items-center">
                    <h2 class="h6 mb-0"><i class="bi bi-broadcast me-2 text-danger"></i> Прямой эфир: @Model.Name</h2>
                    <span id="recBadge" class="badge bg-danger animate-pulse" style="display:none">REC</span>
                </div>
                <div class="card-body p-0 bg-black d-flex align-items-center justify-content-center" style="height: 450px; overflow: hidden;">
                    <div id="loading" class="text-center opacity-50">
                        <i class="bi bi-camera-video display-1 mb-3"></i>
                        <p id="statusText">Подключение к видеопотоку...</p>
                    </div>
                    <img id="videoStream" style="display:none; width: 100%; height: 100%; object-fit: contain;" />
                </div>
                <div class="card-footer bg-transparent border-secondary py-3">
                    <div class="d-flex justify-content-center gap-4">
                        @if (Model.IsPtzSupported)
                        {
                            <div class="ptz-controls">
                                <div class="d-grid gap-1" style="grid-template-columns: repeat(3, 40px);">
                                    <div></div>
                                    <button class="btn btn-sm btn-outline-light"><i class="bi bi-chevron-up"></i></button>
                                    <div></div>
                                    <button class="btn btn-sm btn-outline-light"><i class="bi bi-chevron-left"></i></button>
                                    <button class="btn btn-sm btn-light text-dark"><i class="bi bi-dot"></i></button>
                                    <button class="btn btn-sm btn-outline-light"><i class="bi bi-chevron-right"></i></button>
                                    <div></div>
                                    <button class="btn btn-sm btn-outline-light"><i class="bi bi-chevron-down"></i></button>
                                    <div></div>
                                </div>
                            </div>
                        }
                        <div class="zoom-controls d-flex flex-column gap-2">
                            <button class="btn btn-sm btn-outline-light"><i class="bi bi-plus-lg"></i> Zoom</button>
                            <button class="btn btn-sm btn-outline-light"><i class="bi bi-dash-lg"></i> Zoom</button>
                        </div>
                        <div class="action-controls d-flex flex-column gap-2">
                            <button class="btn btn-sm btn-primary" onclick="takeSnapshot()"><i class="bi bi-camera me-1"></i> Сделать снимок</button>
                            <button class="btn btn-sm btn-outline-warning" onclick="restartStream()"><i class="bi bi-arrow-clockwise me-1"></i> Перезагрузить</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Снимки и статистика -->
        <div class="col-lg-4">
            <div class="card shadow-sm mb-3">
                <div class="card-header bg-light py-2">
                    <h3 class="h6 mb-0">Последние снимки</h3>
                </div>
                <div class="card-body p-2">
                    <div id="snapshots" class="row g-2">
                        @if (ViewBag.LastSnapshots != null && ((List<RtspViewer.Models.Snapshot>)ViewBag.LastSnapshots).Any())
                        {
                            @foreach (var snap in (List<RtspViewer.Models.Snapshot>)ViewBag.LastSnapshots)
                            {
                                <div class="col-6">
                                    <div class="position-relative border rounded overflow-hidden bg-light" style="height: 100px;">
                                        <img src="@snap.FilePath" class="w-100 h-100 object-fit-cover" onclick="window.open(this.src)" style="cursor:pointer" />
                                        <div class="position-absolute bottom-0 start-0 w-100 bg-dark bg-opacity-50 text-white p-1" style="font-size: 0.65rem;">
                                            @snap.CreatedAt.ToLocalTime().ToString("HH:mm:ss")
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="col-12 text-center text-muted small py-4">Снимков пока нет</div>
                        }
                    </div>
                    <div class="d-grid mt-3">
                        <a asp-action="Snapshots" asp-route-cameraId="@Model.Id" class="btn btn-outline-primary btn-sm">Все снимки</a>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-light py-2">
                    <h3 class="h6 mb-0">Информация</h3>
                </div>
                <div class="card-body p-0">
                    <table class="table table-sm mb-0 small">
                        <tbody>
                            <tr><th class="ps-3 bg-light" style="width: 40%;">Статус</th><td id="connStatus" class="ps-3 text-warning fw-bold">Подключение...</td></tr>
                            <tr><th class="ps-3 bg-light">IP/URL</th><td class="ps-3">@Model.RtspUrl</td></tr>
                            <tr><th class="ps-3 bg-light">PTZ</th><td class="ps-3">@(Model.IsPtzSupported ? "Да" : "Нет")</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .animate-pulse {
        animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }
    @@keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: .5; }
    }
    .bg-black { background-color: #000 !important; }
</style>

@section Scripts {
    <script>
        let streamInterval;
        const cameraId = @Model.Id;

        async function startStream() {
            try {
                const response = await fetch(`/Cameras/StartStream/${cameraId}`, { method: 'POST' });
                const data = await response.json();
                
                if (data.success) {
                    document.getElementById('loading').style.display = 'none';
                    document.getElementById('videoStream').style.display = 'block';
                    document.getElementById('recBadge').style.display = 'block';
                    document.getElementById('connStatus').innerText = 'Онлайн';
                    document.getElementById('connStatus').className = 'ps-3 text-success fw-bold';
                    
                    streamInterval = setInterval(() => {
                        document.getElementById('videoStream').src = `/Cameras/GetFrame?t=${Date.now()}`;
                    }, 100);
                } else {
                    document.getElementById('statusText').innerText = 'Ошибка: ' + data.error;
                }
            } catch (e) {
                document.getElementById('statusText').innerText = 'Ошибка подключения';
            }
        }

        function restartStream() {
            clearInterval(streamInterval);
            document.getElementById('loading').style.display = 'flex';
            document.getElementById('videoStream').style.display = 'none';
            startStream();
        }

        async function takeSnapshot() {
            try {
                const response = await fetch(`/Cameras/TakeSnapshot/${cameraId}`, { method: 'POST' });
                const data = await response.json();
                
                if (data.success) {
                    // Добавляем новый снимок в начало списка
                    const container = document.getElementById('snapshots');
                    const emptyMsg = container.querySelector('.col-12');
                    if (emptyMsg) emptyMsg.remove();

                    const html = `
                        <div class="col-6">
                            <div class="position-relative border rounded overflow-hidden bg-light" style="height: 100px;">
                                <img src="${data.filePath}" class="w-100 h-100 object-fit-cover" onclick="window.open(this.src)" style="cursor:pointer" />
                                <div class="position-absolute bottom-0 start-0 w-100 bg-dark bg-opacity-50 text-white p-1" style="font-size: 0.65rem;">
                                    ${data.createdAt}
                                </div>
                            </div>
                        </div>
                    `;
                    container.insertAdjacentHTML('afterbegin', html);
                    
                    // Ограничиваем до 6 снимков
                    const items = container.querySelectorAll('.col-6');
                    if (items.length > 6) items[items.length - 1].remove();
                } else {
                    alert('Ошибка: ' + data.error);
                }
            } catch (e) {
                alert('Ошибка при создании снимка');
            }
        }

        // Запуск при загрузке
        startStream();

        // Остановка при уходе со страницы
        window.onbeforeunload = () => {
            clearInterval(streamInterval);
        };
    </script>
}
